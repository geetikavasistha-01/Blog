# Copy this to .env and fill in real values
# NEVER commit .env itself

ADMIN_PASSWORD_HASH=generate_with_bcrypt_see_readme
SECRET_KEY=generate_with_secrets_token_hex_32
ANALYTICS_SALT=generate_with_secrets_token_hex_32
ENVIRONMENT=production
DATABASE_URL=sqlite:////app/data/blog.db # or postgresql://user:pass@host:5432/dbname

# Startup database seeding (set to true to seed example posts/tags)
SEED_DEMO_DATA=false

# Admin email for testing/QA (automatically subscribed on startup)
ADMIN_EMAIL=admin@example.com

# Site URL for generating absolute links (e.g. in emails)
SITE_URL=https://geekykunoichi.com

# SMTP email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true

# Giscus comments configuration
GISCUS_REPO=your-username/your-repo
GISCUS_REPO_ID=R_...
GISCUS_CATEGORY=Announcements
GISCUS_CATEGORY_ID=DIC_...

# Startup database seeding (set to true to seed example posts/tags)
SEED_DEMO_DATA=false

